# Copie este arquivo para .env e preencha com as SUAS credenciais.
# O arquivo .env NÃO deve ir para o GitHub (já está no .gitignore).

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
# No XAMPP, por padrão o usuário root NÃO tem senha: deixe em branco.
MYSQL_PASSWORD=
MYSQL_DATABASE=transparencia
